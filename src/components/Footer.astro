---
const currentYear = new Date().getFullYear();

const quickLinks = [
  { label: 'Servicios', href: '#servicios' },
  { label: 'Nosotros', href: '#nosotros' },
  { label: 'Equipo', href: '#equipo' },
  { label: 'Contacto', href: '#contacto' },
];
---

<footer class="bg-brand-blue-dark py-12 lg:py-16 text-white">
  <div class="mx-auto max-w-7xl px-4 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 mb-10">
      <!-- Brand -->
      <div>
        <div class="flex items-center gap-2 mb-4">
          <svg class="h-8 w-8 text-brand-orange" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10" />
            <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z" />
          </svg>
          <span class="text-xl font-bold">Taller Gerardito</span>
        </div>
        <p class="text-white/60 text-sm leading-relaxed">
          Con la mejor preparación en sistemas de encendido electrónico. Más de 10 años al servicio de San Manuel y la región norte de Honduras.
        </p>
      </div>

      <!-- Quick links -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white/80 mb-4">Enlaces Rápidos</h3>
        <ul class="space-y-2">
          {quickLinks.map((link) => (
            <li>
              <a href={link.href} class="text-white/60 hover:text-brand-orange transition-colors text-sm">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact & social -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white/80 mb-4">Contacto</h3>
        <ul class="space-y-2 text-white/60 text-sm">
          <li>
            <a href="tel:+50489638660" class="hover:text-brand-orange transition-colors">8963-8660</a>
          </li>
          <li>
            <a href="mailto:gerarnoe21@gmail.com" class="hover:text-brand-orange transition-colors">gerarnoe21@gmail.com</a>
          </li>
          <li>San Manuel, Cortés, Honduras</li>
        </ul>

        <!-- Social media -->
        <div class="flex gap-3 mt-4">
          <a href="#" aria-label="Facebook" class="flex h-10 w-10 items-center justify-center rounded-lg bg-white/10 text-white/60 hover:bg-brand-orange hover:text-white transition-all">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
            </svg>
          </a>
          <a href="#" aria-label="Instagram" class="flex h-10 w-10 items-center justify-center rounded-lg bg-white/10 text-white/60 hover:bg-brand-orange hover:text-white transition-all">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z" />
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Copyright -->
    <div class="border-t border-white/10 pt-6 text-center">
      <p class="text-white/40 text-sm">
        &copy; {currentYear} Taller Gerardito. Todos los derechos reservados.
      </p>
    </div>
  </div>
</footer>
