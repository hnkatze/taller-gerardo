---
const contactInfo = [
  {
    label: 'Teléfono / WhatsApp',
    value: '8963-8660',
    href: 'tel:+50489638660',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>`,
  },
  {
    label: 'WhatsApp Directo',
    value: 'Escríbenos por WhatsApp',
    href: 'https://wa.me/50489638660',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>`,
    external: true,
  },
  {
    label: 'Correo Electrónico',
    value: 'gerarnoe21@gmail.com',
    href: 'mailto:gerarnoe21@gmail.com',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>`,
  },
  {
    label: 'Dirección',
    value: 'San Manuel, Cortés — 2 cuadras arriba del Carwash Mendoza',
    href: '#mapa',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>`,
  },
];
---

<section id="contacto" class="py-20 lg:py-28">
  <div class="mx-auto max-w-7xl px-4 lg:px-8">
    <div class="text-center mb-16" data-animate="fade-up">
      <h2 class="text-section-title font-bold text-neutral-800 mb-4">Contáctanos</h2>
      <p class="text-lg text-neutral-600 max-w-2xl mx-auto">
        Estamos listos para atenderte. Contáctanos por cualquiera de estos medios o visítanos en nuestro taller.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8 max-w-4xl mx-auto" data-animate="stagger">
      {contactInfo.map((item) => (
        <a
          href={item.href}
          target={item.external ? '_blank' : undefined}
          rel={item.external ? 'noopener' : undefined}
          class="flex items-start gap-4 rounded-2xl bg-white p-6 shadow-sm border border-neutral-200 transition-all hover:shadow-md hover:border-brand-orange/30 group"
        >
          <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-brand-blue/10 text-brand-blue group-hover:bg-brand-orange/10 group-hover:text-brand-orange transition-colors">
            <Fragment set:html={item.icon} />
          </div>
          <div>
            <div class="text-sm font-medium text-neutral-500 mb-1">{item.label}</div>
            <div class="text-base font-semibold text-neutral-800">{item.value}</div>
          </div>
        </a>
      ))}
    </div>

    <!-- Business hours -->
    <div class="mt-12 max-w-md mx-auto text-center" data-animate="fade-up">
      <div class="rounded-2xl bg-brand-blue p-6 text-white">
        <svg class="h-8 w-8 mx-auto mb-3 text-brand-orange" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="10" />
          <polyline points="12 6 12 12 16 14" />
        </svg>
        <h3 class="text-lg font-semibold mb-2">Horario de Atención</h3>
        <p class="text-white/80">Lunes a Sábado</p>
        <p class="text-xl font-bold text-brand-orange">8:00 a.m. a 5:00 p.m.</p>
      </div>
    </div>
  </div>
</section>
